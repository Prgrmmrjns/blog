ass=\"relative z-10 mx-auto max-w-3xl\">\n        <p class=\"mb-4 text-sm font-medium tracking-[0.3em] uppercase text-mint\">\n          100% Plant-Based\n        </p>\n        <h1 class=\"text-5xl font-extrabold leading-tight tracking-tight text-cream sm:text-7xl\">\n          Verdant Kitchen\n        </h1>\n        <p class=\"mt-6 text-lg font-light leading-relaxed text-cream/60\">\n          Cinematic vegan recipes crafted with love.<br />\n          Dishes that look as stunning as they taste.\n        </p>\n        <div class=\"mx-auto mt-8 h-px w-24 bg-gradient-to-r from-transparent via-gold to-transparent\" />\n      </div>\n    </header>\n\n    <!-- Recipe Cards -->\n    <main class=\"mx-auto max-w-6xl px-6 pb-32\">\n      <div class=\"grid gap-10 sm:grid-cols-2 lg:grid-cols-3\">\n        <NuxtLink\n          v-for=\"recipe in recipes\"\n          :key=\"recipe.slug\"\n          :to=\"`/recipe/${recipe.slug}`\"\n          class=\"group relative overflow-hidden rounded-2xl bg-[#161616] transition-all duration-500 hover:scale-[1.02] hover:shadow-[0_20px_60px_-10px_rgba(122,218,165,0.15)]\"\n        >\n          <div class=\"relative aspect-[4/3] overflow-hidden\">\n            <img\n              :src=\"recipe.image\"\n              :alt=\"recipe.title\"\n              class=\"h-full w-full object-cover transition-transform duration-700 group-hover:scale-110\"\n              loading=\"lazy\"\n            />\n            <div class=\"absolute inset-0 bg-gradient-to-t from-[#0e0e0e] via-[#0e0e0e]/40 to-transparent\" />\n            <div class=\"absolute inset-0 shadow-[inset_0_-80px_60px_-30px_rgba(0,0,0,0.8)]\" />\n          </div>\n\n          <div class=\"relative -mt-16 z-10 p-6 pt-0\">\n            <span class=\"mb-2 inline-block rounded-full bg-gold/20 px-3 py-1 text-xs font-semibold tracking-wider uppercase text-gold\">\n              {{ recipe.difficulty }}\n            </span>\n            <h2 class=\"mt-2 text-2xl font-bold text-cream transition-colors duration-300 group-hover:text-mint\">\n              {{ recipe.title }}\n            </h2>\n            <p class=\"mt-2 text-sm font-light text-cream/50\">\n              {{ recipe.tagline }}\n            </p>\n            <div class=\"mt-4 flex items-center gap-4 text-xs text-cream/40\">\n              <span class=\"flex items-center gap-1\">\n                <IconClock class=\"h-3.5 w-3.5\" />\n                {{ recipe.prepTime }} prep\n              </span>\n              <span class=\"flex items-center gap-1\">\n                <IconFlame class=\"h-3.5 w-3.5\" />\n                {{ recipe.cookTime }} cook\n              </span>\n            </div>\n          </div>\n        </NuxtLink>\n      </div>\n    </main>\n\n    <!-- Footer -->\n    <footer class=\"border-t border-white/5 py-12 text-center text-xs text-cream/30\">\n      Verdant Kitchen &mdash; Plant-Powered Cooking\n    </footer>\n  </div>\n</template>\n"],"version":3}