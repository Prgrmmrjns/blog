{"file":"index-DB6xdqs3.js","mappings":";;;;;;;;;;;;;;;;;;;;;AACA,UAAM,EAAE,MAAM,WAAU,CAAA,QAAA,SAAA,IAAAA,iBAAA,MAAM;AAAA,MAAa;AAAA,MAAc,MACvD,gBAAgB,OAAO,EAAE,MAAM,QAAQ,MAAM,EAAE,IAAA;AAAA,IAAI,CACrD;;;AAIO,YAAA,OAAAC,eAAAC,WAAA,EAAA,OAAM,iDAA6C,MAAA,CAAA,CAAA,swFAAA;AAkEjCC,oBAAAC,MAAA,KAAA,UAAR,SAAI;;UACV,KAAK,KAAK;AAAA,UACV,IAAI,KAAK;AAAA,UACV,OAAM;AAAA,QAAA;2BAJR,CAyCW,GAAAC,QAAAC,UAAA,aAAA;;;AAjCC,kBAAA,KAAK,OAAK;4CACf,OAAK,KAAK,KAAK,kBACf,OAAK,KAAK,KAAK;;;;;AAcCH,6BAAA,KAAK,QAAI,CAAA,GAAQ,cAAzB,QAAG;sIAIP,GAAG;;mMAILI,eAAA,KAAK,KAAK,qGAGVA,eAAA,KAAK,OAAO,4EAGZA,eAAA,KAAK,IAAI;;;gBAhChBC,YAaM,OAAA,EAbD,OAAM,2CAAuC;AAAA,kBAExC,KAAK,sBADbC,YAME,OAAA;AAAA;oBAJC,KAAK,KAAK;AAAA,oBACV,KAAK,KAAK;AAAA,oBACX,OAAM;AAAA,oBACN,SAAQ;AAAA,kBAAA,6CAEVA,YAEM,OAAA;AAAA;oBAFM,OAAM;AAAA,kBAAA,GAAkF,KAEpG;AAAA,kBACAD,YAA0I,OAAA,EAArI,OAAM,8HAA4H;AAAA,kBACvIA,YAAkF,OAAA,EAA7E,OAAM,sEAAoE;AAAA,gBAAA;gBAGjFA,YAmBM,OAAA,EAnBD,OAAM,mCAA+B;AAAA,kBACxCA,YAQM,OAAA,EARD,OAAM,+BAA2B;AAAA,qBACpCE,UAAA,IAAA,GAAAD,YAMOE,4BALU,KAAK,QAAI,CAAA,GAAQ,cAAzB,QAAG;0CADZF,YAMO,QAAA;AAAA,wBAJJ,KAAK;AAAA,wBACN,OAAM;AAAA,sBAAA,mBAEH,GAAG,GAAA,CAAA;AAAA;;kBAGVD,YAEK,QAFD,OAAM,wIAAA,GAAuII,gBAC5I,KAAK,KAAK,GAAA,CAAA;AAAA,kBAEfJ,YAEI,OAFD,OAAM,wEAAA,GAAuEI,gBAC3E,KAAK,OAAO,GAAA,CAAA;AAAA,kBAEjBJ,YAEI,OAFD,OAAM,gDAAA,GAA+CI,gBACnD,KAAK,IAAI,GAAA,CAAA;AAAA,gBAAA;;;;;;;;;;;;;;;;;","names":["_withAsyncContext","_ssrRenderAttrs","_mergeProps","_ssrRenderList","_unref","_push","_parent","_ssrInterpolate","_createVNode","_createBlock","_openBlock","_Fragment","_toDisplayString"],"sources":["../../../../../../../app/pages/index.vue"],"sourcesContent":["<script setup lang=\"ts\">\nconst { data: posts } = await useAsyncData(\"posts-list\", () =>\n  queryCollection(\"posts\").order(\"date\", \"DESC\").all()\n);\n</script>\n\n<template>\n  <div class=\"min-h-screen bg-[#f5f3eb] dark:bg-[#0e0e0e]\">\n    <!-- Header -->\n    <header class=\"relative overflow-hidden py-24 px-6 text-center\">\n      <div class=\"absolute inset-0 bg-gradient-to-b from-teal/10 via-transparent to-transparent\" />\n      <div class=\"relative z-10 mx-auto max-w-3xl\">\n        <p class=\"mb-4 text-sm font-medium tracking-[0.3em] uppercase text-teal dark:text-mint\">\n          Science · AI · Programming · Medicine · Health & Fitness\n        </p>\n        <h1 class=\"text-5xl font-extrabold leading-tight tracking-tight text-gray-900 dark:text-cream sm:text-7xl\">\n          Jonas Wolber\n        </h1>\n        <p class=\"mt-6 text-lg font-light leading-relaxed text-gray-600 dark:text-cream/60\">\n          Curiosity is all you need.<br />\n          Doctoral student in Computational Biomedicine · RWTH Aachen\n        </p>\n        <div class=\"mx-auto mt-8 h-px w-24 bg-gradient-to-r from-transparent via-gold to-transparent\" />\n      </div>\n    </header>\n\n    <!-- About -->\n    <section class=\"mx-auto max-w-4xl px-6 py-16\">\n      <h2 class=\"mb-6 text-xl font-bold text-gold\">About</h2>\n      <div class=\"space-y-3 text-[15px] leading-relaxed text-gray-800 dark:text-cream/80\">\n        <p>\n          I'm a doctoral student at University Hospital RWTH Aachen, affiliated with the Institute for Digitalization and General Medicine and the Institute for Computational Biomedicine Aachen.\n        </p>\n        <p>\n          My research focuses on metabolic diseases, diabetes, remote monitoring, machine learning, time series, LLMs, and hybrid modeling. I studied Biomedical Sciences at Maastricht and Cardiovascular Science at Göttingen.\n        </p>\n        <p class=\"text-gray-600 dark:text-cream/60\">\n          <strong>p(doom):</strong> 5%. The world would be better if everyone were a bit more tolerant—and more concerned about restoring our beautiful nature.\n        </p>\n      </div>\n      <div class=\"mt-8 flex flex-wrap gap-4\">\n        <a\n          href=\"https://www.linkedin.com/in/jonas-wolber/\"\n          target=\"_blank\"\n          rel=\"noopener noreferrer\"\n          class=\"rounded-full border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:border-teal hover:text-teal dark:border-white/20 dark:text-cream/80 dark:hover:border-mint/50 dark:hover:text-mint\"\n        >\n          LinkedIn\n        </a>\n        <a\n          href=\"https://github.com/Prgrmmrjns\"\n          target=\"_blank\"\n          rel=\"noopener noreferrer\"\n          class=\"rounded-full border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:border-teal hover:text-teal dark:border-white/20 dark:text-cream/80 dark:hover:border-mint/50 dark:hover:text-mint\"\n        >\n          GitHub\n        </a>\n        <a\n          href=\"https://www.researchgate.net/profile/Jonas-Wolber-4\"\n          target=\"_blank\"\n          rel=\"noopener noreferrer\"\n          class=\"rounded-full border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:border-teal hover:text-teal dark:border-white/20 dark:text-cream/80 dark:hover:border-mint/50 dark:hover:text-mint\"\n        >\n          ResearchGate\n        </a>\n      </div>\n    </section>\n\n    <!-- Latest Posts -->\n    <main class=\"mx-auto max-w-6xl px-6 pb-32\">\n      <h2 class=\"mb-10 text-xl font-bold text-gold\">Latest posts</h2>\n      <div class=\"grid gap-10 sm:grid-cols-2 lg:grid-cols-3\">\n        <NuxtLink\n          v-for=\"post in posts ?? []\"\n          :key=\"post.path\"\n          :to=\"post.path\"\n          class=\"group relative overflow-hidden rounded-2xl bg-white shadow-lg transition-all duration-500 hover:scale-[1.02] hover:shadow-xl dark:bg-[#161616] dark:shadow-none dark:hover:shadow-[0_20px_60px_-10px_rgba(122,218,165,0.15)]\"\n        >\n          <div class=\"relative aspect-[4/3] overflow-hidden\">\n            <img\n              v-if=\"post.image\"\n              :src=\"post.image\"\n              :alt=\"post.title\"\n              class=\"h-full w-full object-cover transition-transform duration-700 group-hover:scale-110\"\n              loading=\"lazy\"\n            />\n            <div v-else class=\"flex h-full w-full items-center justify-center bg-teal/10 text-4xl text-teal/40\">\n              #\n            </div>\n            <div class=\"absolute inset-0 bg-gradient-to-t from-[#f5f3eb] via-[#f5f3eb]/40 to-transparent dark:from-[#0e0e0e] dark:via-[#0e0e0e]/40\" />\n            <div class=\"absolute inset-0 shadow-[inset_0_-80px_60px_-30px_rgba(0,0,0,0.8)]\" />\n          </div>\n\n          <div class=\"relative -mt-16 z-10 p-6 pt-0\">\n            <div class=\"mb-2 flex flex-wrap gap-2\">\n              <span\n                v-for=\"tag in (post.tags ?? []).slice(0, 2)\"\n                :key=\"tag\"\n                class=\"rounded-full bg-gold/20 px-2 py-0.5 text-xs font-semibold text-gold\"\n              >\n                {{ tag }}\n              </span>\n            </div>\n            <h3 class=\"mt-2 text-2xl font-bold text-gray-900 transition-colors duration-300 group-hover:text-teal dark:text-cream dark:group-hover:text-mint\">\n              {{ post.title }}\n            </h3>\n            <p class=\"mt-2 text-sm font-light text-gray-600 line-clamp-2 dark:text-cream/50\">\n              {{ post.excerpt }}\n            </p>\n            <p class=\"mt-4 text-xs text-gray-500 dark:text-cream/40\">\n              {{ post.date }}\n            </p>\n          </div>\n        </NuxtLink>\n      </div>\n    </main>\n\n    <!-- Footer -->\n    <footer class=\"border-t border-gray-200 py-12 text-center text-xs text-gray-500 dark:border-white/5 dark:text-cream/30\">\n      Jonas Wolber · Curiosity is all you need.\n    </footer>\n  </div>\n</template>\n"],"version":3}